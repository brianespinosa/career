{
  "name": "career",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check": "biome check --write .",
    "data-types": "./json-d-ts.sh",
    "dev": "next dev",
    "e2e": "playwright test",
    "em": "mlr --c2j --jlistwrap cat data/em.csv > data/em.json",
    "ic": "mlr --c2j --jlistwrap cat data/ic.csv > data/ic.json",
    "knip": "knip",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      "Chrome >= 90",
      "Edge >= 90",
      "Firefox >= 90",
      "Safari >= 15",
      "iOS >= 15",
      "not dead"
    ]
  },
  "dependencies": {
    "@radix-ui/colors": "3.0.0",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/themes": "3.3.0",
    "@react-spring/web": "10.0.3",
    "@visx/visx": "4.0.1-alpha.0",
    "d3-shape": "3.2.0",
    "motion": "12.35.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "happy-dom": "20.8.3",
    "knip": "5.86.0",
    "lefthook": "2.1.3",
    "normalize.css": "8.0.1",
    "sass": "1.97.3",
    "typescript": "5.9.3",
    "vercel": "50.28.0",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "knip": {
    "ignoreDependencies": [
      "@react-spring/web",
      "@visx/*",
      "normalize.css"
    ],
    "ignoreBinaries": [
      "mlr"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
